{
  "name": "voxel-realm",
  "version": "1.0.0",
  "description": "Browser voxel sandbox engine: streamed chunks, greedy meshing with vertex AO, weather, procedural audio, and an in-game builder with blueprints",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "assets:build": "node --disable-warning=ExperimentalWarning scripts/buildAssets.ts",
    "world:archive": "node --disable-warning=ExperimentalWarning scripts/worldArchive.ts",
    "world:restore": "node --disable-warning=ExperimentalWarning scripts/worldRestore.ts",
    "world:package": "node --disable-warning=ExperimentalWarning scripts/worldPackage.ts",
    "world:bundle": "node --disable-warning=ExperimentalWarning scripts/worldBundle.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Edgar1738/voxel-realm.git"
  },
  "keywords": [],
  "author": "Edgar1738 <info@edgarha.com>",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Edgar1738/voxel-realm/issues"
  },
  "homepage": "https://github.com/Edgar1738/voxel-realm#readme",
  "engines": { "node": "^20.19.0 || >=22.12.0" },
  "dependencies": {
    "simplex-noise": "^4.0.3",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@types/node": "^26.0.1",
    "@types/pngjs": "^6.0.5",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
